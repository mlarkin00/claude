{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/install-symlinks.sh\" 2>/dev/null || true",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/scripts/load_context.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/scripts/save_context.py\" 2>/dev/null || true",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/scripts/sidecar_consolidate.py\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
