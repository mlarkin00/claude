# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite

suite_name: "Active Skills Evaluation Suite"
timeout_seconds: 300
scorers: "expectations"
scorers: "triggering"
scorers: "script_validators"

cases {
  name: "trigger_auditing_k8s_config"
  tags: "triggering"
  tags: "fast"
  prompt: "Review my Kubernetes config in k8s.yaml to see if it is production ready."
  setup {
    files { key: "k8s.yaml" value: "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: dummy\n" }
  }
  expected_skills: "active-skills/auditing-k8s-config"
}

