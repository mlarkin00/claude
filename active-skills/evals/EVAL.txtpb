cases {
  name: "test_executing_plans"
  tags: "execution"
  tags: "slow"
  prompt: "I have a design spec and an implementation plan staged in the workspace. Please execute the plan to implement the calculator."
  expectations: "The agent executed the plan, implementing the calculator and passing all tests."
  expected_skills: "active-skills/executing-plans"
  script_validators: "python3 -m unittest execute_calc/calculator_test.py"
  
  setup {
    files {
      key: "docs/agent-workflow/specs/2026-07-07-execute-calc-design.md"
      value: "# Design: Execute Calc\n\n**Status:** Approved\n\n## Requirements\n1. Support add and subtract.\n"
    }
    files {
      key: "docs/agent-workflow/plans/2026-07-07-execute-calc-implementation.md"
      value: "# Plan\n\n## Task 1: Add\n- **Files:** `execute_calc/calculator.py`, `execute_calc/calculator_test.py`\n- **Steps:**\n  1. Write failing test for `add` in `execute_calc/calculator_test.py`.\n  2. Implement `add` in `execute_calc/calculator.py`.\n  3. Verify tests pass.\n\n## Task 2: Subtract\n- **Files:** `execute_calc/calculator.py`, `execute_calc/calculator_test.py`\n- **Steps:**\n  1. Write failing test for `subtract` in `execute_calc/calculator_test.py`.\n  2. Implement `subtract` in `execute_calc/calculator.py`.\n  3. Verify tests pass.\n"
    }
    commands: "rm -rf execute_calc"
  }
  cleanup {
    commands: "rm -rf execute_calc"
    commands: "rm -f docs/agent-workflow/specs/2026-07-07-execute-calc-design.md"
    commands: "rm -f docs/agent-workflow/plans/2026-07-07-execute-calc-implementation.md"
  }
}

