cases {
  name: "test_brainstorming"
  tags: "execution"
  tags: "slow"
  prompt: "I want to create a new CLI tool for managing todo lists. Can we brainstorm some features and design options?"
  expectations: "The agent suggested features or design options before starting implementation."
  expected_skills: "active-skills/brainstorming"
  
  user_simulator {
    goal: "You want to brainstorm features for a todo list tool. You prefer a CLI interface, so you don't need a visual companion."
    rule: "If asked about the visual companion, decline it."
    rule: "Answer clarifying questions cooperatively. You want basic features like add, list, delete, and marking as done."
    max_interactions: 5
  }
}

cases {
  name: "trigger_close_session"
  tags: "triggering"
  tags: "fast"
  prompt: "Close the session and commit my changes."
  expected_skills: "active-skills/close-session"
}

cases {
  name: "test_designing_code"
  tags: "execution"
  tags: "slow"
  prompt: "We want to support custom operations in our calculator (located in `plugin_calculator/calculator.py`) via a plugin system. Please design this plugin system and write a design document. Make reasonable assumptions for unspecified details and document them. Do not ask for clarification."
  expectations: "The agent created a structured design document capturing the architecture and design decisions for the plugin system."
  expected_skills: "active-skills/designing-code"
  
  setup {
    files {
      key: "plugin_calculator/calculator.py"
      value: "class Calculator:\n  def add(self, a, b):\n    return a + b\n  def subtract(self, a, b):\n    return a - b\n"
    }
    commands: "rm -f DESIGN.md plugin_calculator/DESIGN.md"
  }
  cleanup {
    commands: "rm -f DESIGN.md plugin_calculator/DESIGN.md"
    commands: "rm -rf plugin_calculator"
  }
  user_simulator {
    goal: "You want a design for a plugin system. You prefer a simple directory-based plugin discovery (e.g., loading .py files from a plugins/ directory) and a class-based interface."
    rule: "Answer clarifying questions about plugin discovery by suggesting directory-based loading."
    rule: "Answer clarifying questions about interface by suggesting a class with a standard method."
  }
}

