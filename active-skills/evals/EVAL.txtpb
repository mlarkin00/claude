cases {
  name: "test_debugging"
  tags: "execution"
  tags: "slow"
  prompt: "The `find_max` function in `buggy_math/buggy_math.py` is failing for lists containing only negative numbers. Please investigate the root cause, write a failing test, and fix the bug."
  expectations: "The agent identified the root cause (initialization of max_val to 0), wrote a failing test case for negative numbers, and fixed the bug by initializing max_val correctly."
  expected_skills: "active-skills/systematic-debugging"
  script_validators: "python3 -m unittest buggy_math/buggy_math_test.py"
  
  setup {

    files {
      key: "buggy_math/__init__.py"
      value: "from .buggy_math import find_max\n"
    }
    files {
      key: "buggy_math/buggy_math.py"
      value: "def find_max(numbers):\n  if not numbers:\n    raise ValueError(\"List is empty\")\n  max_val = 0\n  for n in numbers:\n    if n > max_val:\n      max_val = n\n  return max_val\n"
    }
    files {
      key: "buggy_math/buggy_math_test.py"
      value: "import unittest\nfrom buggy_math import find_max\n\nclass TestBuggyMath(unittest.TestCase):\n  def test_positive(self):\n    self.assertEqual(find_max([1, 5, 3]), 5)\n\nif __name__ == '__main__':\n  unittest.main()\n"
    }
  }
  cleanup {
    commands: "rm -rf buggy_math"
  }
}

cases {
  name: "test_tdd"
  tags: "execution"
  tags: "slow"
  prompt: "Use Test-Driven Development (TDD) to implement a function `factorial(n)` in `math_utils.py` and write tests for it in `math_utils_test.py`."
  expectations: "The agent used Test-Driven Development (TDD), writing a failing test before implementing the code."
  expected_skills: "active-skills/test-driven-development"
  script_validators: "python3 -m unittest math_utils_test.py"
  
  setup {
    commands: "rm -f math_utils.py math_utils_test.py test_math_utils.py"
    commands: "rm -rf tests"
    commands: "rm -rf __pycache__"
  }
  cleanup {
    commands: "rm -f math_utils.py math_utils_test.py test_math_utils.py"
    commands: "rm -rf tests"
    commands: "rm -rf __pycache__"
  }
}

