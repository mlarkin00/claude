cases {
  name: "test_writing_plans"
  tags: "execution"
  tags: "slow"
  prompt: "I have a requirement to implement a simple calculator. An approved design spec is already available in the workspace. Please find it and write an implementation plan. Save the plan to `docs/agent-workflow/plans/2026-07-07-simple-calculator.md` as a regular file (do not use ArtifactMetadata in the write_to_file tool call)."
  expectations: "The agent wrote a structured implementation plan."
  expected_skills: "active-skills/writing-plans"
  setup {
    files {
      key: "docs/agent-workflow/specs/2026-07-07-calculator-design.md"
      value: "# Design: Simple Calculator\n\n**Status:** Approved\n**Author:** Test Setup\n**Date:** 2026-07-07\n\n## Context\nWe need a simple calculator library in Python.\n\n## Requirements\n### Functional\n1. Support addition of two numbers.\n2. Support subtraction of two numbers.\n3. Support multiplication of two numbers.\n4. Support division of two numbers.\n   - Handle division by zero by raising ValueError.\n\n## Design\n### API / Interface Design\nWe will implement a `Calculator` class in `calculator/calculator.py`.\n\nMethods:\n- `add(a, b)`\n- `subtract(a, b)`\n- `multiply(a, b)`\n- `divide(a, b)`\n"
    }
    commands: "rm -rf calculator"
    commands: "rm -rf docs/agent-workflow/plans/*"
  }
  cleanup {
    commands: "rm -f docs/agent-workflow/specs/2026-07-07-calculator-design.md"
    commands: "rm -rf docs/agent-workflow/plans/*"
    commands: "rm -rf calculator"
  }
}

