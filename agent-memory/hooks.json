{
  "agent-memory-pull": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "bash ./scripts/agy-session-start.sh",
        "timeout": 30
      }
    ]
  },
  "agent-memory-push": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/memory-push.sh >/dev/null || true; printf '{}\\n'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
