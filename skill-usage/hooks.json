{
  "skill-usage": {
    "enabled": true,
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/track-usage-agy.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ./scripts/sync-usage.py --min-interval 1800 >/dev/null 2>&1 || true; printf '{}\\n'",
        "timeout": 20
      }
    ]
  }
}
